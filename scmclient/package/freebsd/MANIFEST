name: ${APP_NAME}
version: "${VERSION}"
origin: sysutils/${APP_NAME}
comment: "OpenSCM Agent"
desc: "Security Compliance Monitoring agent"
maintainer: "yariv@openscm.io"
www: "https://openscm.io"
prefix: /usr/local
licenselogic: single
licenses: [Apache-2.0]
arch: ${ARCH}
categories: [sysutils]
files: {
    /usr/local/bin/${APP_NAME}: "-",
    /usr/local/etc/rc.d/${APP_NAME}: "-"
}
scripts: {
    post-install: <<EOD
#!/bin/sh
CONFIG_DIR="/usr/local/etc/openscm"
KEYS_DIR="/usr/local/etc/openscm/keys"
LOG_DIR="/var/log/openscm"
mkdir -p "$CONFIG_DIR"
mkdir -p "$KEYS_DIR"
mkdir -p "$LOG_DIR"
chmod 755 "$CONFIG_DIR"
chmod 700 "$KEYS_DIR"
chmod 755 "$LOG_DIR"
sysrc ${APP_NAME}_enable=YES
EOD
    pre-deinstall: <<EOD
#!/bin/sh
service ${APP_NAME} stop >/dev/null 2>&1 || true
sysrc -x ${APP_NAME}_enable >/dev/null 2>&1 || true
EOD
    post-deinstall: <<EOD
#!/bin/sh
rm -rf /var/log/openscm
EOD
}
