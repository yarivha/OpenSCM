#!/bin/sh
set -e

APP_NAME="scmclient"
LOG_DIR="/var/log/openscm"

if [ "$1" = "purge" ] || [ "$1" = "0" ]; then
    echo "Removing logs and configuration for $APP_NAME..."
    rm -f "$LOG_DIR/scmclient*"
    rm -f /etc/openscm/scmclient.config
fi

if [ "$1" = "remove" ] || [ "$1" = "0" ] || [ "$1" = "1" ]; then
    if [ -d /run/systemd/system ]; then
        systemctl daemon-reload >/dev/null 2>&1 || true
    fi
fi

exit 0
