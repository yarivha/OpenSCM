[Unit]
Description=OpenSCM Server Service
After=network.target

[Service]
Type=simple
ExecStart=/opt/openscm/scmserver
WorkingDirectory=/opt/openscm
Restart=on-failure
User=root

# Logs
StandardOutput=append:/var/log/openscm/scmserver_output.log
StandardError=append:/var/log/openscm/scmserver_error.log

[Install]
WantedBy=multi-user.target
